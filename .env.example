# Token do bot Discord
DISCORD_TOKEN=SEU_TOKEN_AQUI

# Preferencial: ID do canal de logs. Aceita também formato <#123...>
LOG_CHANNEL_ID=

# Fallback se LOG_CHANNEL_ID não for definido ou não for encontrado
LOG_CHANNEL_NAME=📜logs

# Dias para manter logs do bot no canal de logs. Intervalo aceito: 1 a 90
LOG_RETENTION_DAYS=5
